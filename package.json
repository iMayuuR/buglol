{
  "name": "error-sound-effect",
  "displayName": "BugLOL - 100K+ Error Sound Effects",
  "description": "Plays a trending meme sound when your code hits an error! 🔊 One-click status bar, ⌨️ Ctrl+Shift+M shortcut, 🔍 Search 100k+ sounds instantly.",
  "version": "1.5.0",
  "publisher": "iMayuuR",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/iMayuuR/BugLOL"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sound",
    "error",
    "meme",
    "funny",
    "sound effect",
    "buglol",
    "error sound",
    "bug sound",
    "debug",
    "debugging",
    "fun",
    "comedy",
    "troll",
    "prank",
    "audio",
    "notification",
    "alert",
    "terminal error",
    "terminal sound",
    "coding fun",
    "developer tools",
    "meme sound",
    "trending sounds",
    "sound board",
    "error alert"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "errorSoundEffect.selectSound",
        "title": "BugLOL: Search Sounds 🎵",
        "icon": "$(music)"
      },
      {
        "command": "errorSoundEffect.toggleEnabled",
        "title": "BugLOL: Toggle On/Off"
      }
    ],
    "keybindings": [
      {
        "command": "errorSoundEffect.selectSound",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "configuration": {
      "title": "Error Sound Effect Settings",
      "properties": {
        "errorSoundEffect.selectedSoundName": {
          "type": "string",
          "default": "Fahhh",
          "description": "The currently selected sound name."
        },
        "errorSoundEffect.selectedSoundFilename": {
          "type": "string",
          "default": "fahhh_KcgAXfs.mp3",
          "description": "The downloaded MP3 filename."
        },
        "errorSoundEffect.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable BugLOL error sounds."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo Ready"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.93.0"
  }
}